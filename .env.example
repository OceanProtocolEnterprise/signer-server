    # Node RPC endpoints keyed by chain ID
    PRIVATE_KEY=<PRIVATE_KEY>
    NODE_URI_MAP={"11155111":"https://<your-rpc-provider-url-and-key>"}

    # Authentik (OIDC)
    AUTHENTIK_JWKS_URI=<authentik_jwks_uri>
    AUTHENTIK_ISSUER=<authentik_issuer_url>
    AUTHENTIK_AUDIENCE=<authentik_oidc_client_id>

    # Server
    PORT=3001
    NODE_ENV=development

    # Optional: fallback API key for backward compatibility (optional)
    API_KEY_FALLBACK=changeme
